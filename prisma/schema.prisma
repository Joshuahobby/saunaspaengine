generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id                     String           @id @default(cuid())
  name                   String
  taxId                  String?
  headquarters           String?
  phone                  String?
  status                 EntityStatus     @default(ACTIVE)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  subscriptionCycle      String?
  subscriptionRenewal    DateTime?
  subscriptionPlanId     String?
  approvalStatus         ApprovalStatus   @default(PENDING)
  kycNotes               String?
  kycVerifiedAt          DateTime?
  subscriptionStatus     String?          @default("ACTIVE")
  permissions            Json?
  platformCommissionRate Float            @default(5.0)
  logo                   String?
  primaryColor           String?
  currency               String?          @default("RWF")
  timezone               String?          @default("Africa/Kigali")
  taxLabel               String?          @default("VAT")
  branches               Branch[]
  subscriptionPlan       PlatformPackage? @relation(fields: [subscriptionPlanId], references: [id])
  users                  User[]

  @@map("corporates")
}

model PlatformPackage {
  id           String     @id @default(cuid())
  name         String     @unique
  priceMonthly Float      @default(0)
  priceYearly  Float      @default(0)
  isCustom     Boolean    @default(false)
  description  String?
  branchLimit  Int        @default(3)
  features     String[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  businesses   Business[]

  @@map("platform_packages")
}

model Branch {
  id                   String               @id @default(cuid())
  name                 String
  address              String?
  phone                String?
  email                String?
  logo                 String?
  status               EntityStatus         @default(ACTIVE)
  businessId           String?              @map("corporateId")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  onboardingCompleted  Boolean              @default(false)
  onboardingStep       Int                  @default(0)
  taxId                String?
  taxLabel             String?
  primaryColor         String?
  currency             String?
  timezone             String?
  businessHours        Json?
  auditLogs            AuditLog[]
  broadcasts           Broadcast[]
  business             Business?            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clients              Client[]
  employeeCategories   EmployeeCategory[]
  employees            Employee[]
  inventory            Inventory[]
  inventoryLogs        InventoryLog[]
  loyaltyPrograms      LoyaltyProgram?
  membershipCategories MembershipCategory[]
  safetyAlerts         SafetyAlert[]
  serviceRecords       ServiceRecord[]
  services             Service[]
  suppliers            Supplier[]
  users                User[]
  reviews              Review[]
  shifts               Shift[]
  employeePayouts      EmployeePayout[]

  @@map("businesses")
}

model User {
  id              String       @id @default(cuid())
  username        String       @unique
  email           String       @unique
  passwordHash    String
  fullName        String
  role            UserRole     @default(EMPLOYEE)
  status          EntityStatus @default(ACTIVE)
  usr_branchId    String?      @map("businessId")
  usr_businessId  String?      @map("corporateId")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  resetOtp        String?
  resetOtpExpiry  DateTime?
  auditLogs       AuditLog[]
  employeeProfile Employee?
  branch          Branch?      @relation(fields: [usr_branchId], references: [id], onDelete: Cascade)
  business        Business?    @relation(fields: [usr_businessId], references: [id], onDelete: Cascade)

  @@map("users")
}

model EmployeeCategory {
  id          String       @id @default(cuid())
  name        String
  description String?
  status      EntityStatus @default(ACTIVE)
  branchId    String       @map("businessId")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employees   Employee[]

  @@map("employee_categories")
}

model Employee {
  id             String           @id @default(cuid())
  fullName       String
  phone          String?
  status         EntityStatus     @default(ACTIVE)
  categoryId     String
  branchId       String           @map("businessId")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  commissionRate Float            @default(5.0)
  userId         String?          @unique
  commissionLogs CommissionLog[]
  branch         Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category       EmployeeCategory @relation(fields: [categoryId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])
  serviceRecords ServiceRecord[]
  reviews        Review[]
  shifts         Shift[]
  payouts        EmployeePayout[]

  @@map("employees")
}

model Client {
  id             String          @id @default(cuid())
  fullName       String
  phone          String?
  clientType     ClientType      @default(WALK_IN)
  qrCode         String?         @unique
  membershipCardUrl String?         @db.Text
  status         EntityStatus    @default(ACTIVE)
  branchId       String          @map("businessId")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  loyaltyPoints  LoyaltyPoint[]
  memberships    Membership[]
  serviceRecords ServiceRecord[]
  reviews        Review[]
  notes          String?         @db.Text

  // phone is searched frequently for client lookup
  @@index([phone])
  @@index([branchId, status])
  @@map("clients")
}

model MembershipCategory {
  id           String         @id @default(cuid())
  name         String
  type         MembershipType
  description  String?
  price        Float          @default(0)
  durationDays Int?
  usageLimit   Int?
  status       EntityStatus   @default(ACTIVE)
  branchId     String         @map("businessId")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  isGlobal     Boolean        @default(false)
  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  memberships  Membership[]

  @@map("membership_categories")
}

model Membership {
  id         String             @id @default(cuid())
  clientId   String
  categoryId String
  startDate  DateTime           @default(now())
  endDate    DateTime?
  balance    Int?
  status     EntityStatus       @default(ACTIVE)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  category   MembershipCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  client     Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

model Service {
  id             String          @id @default(cuid())
  name           String
  category       String?
  price          Float
  duration       Int
  status         EntityStatus    @default(ACTIVE)
  branchId       String          @map("businessId")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  serviceRecords ServiceRecord[]
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("services")
}

model ServiceRecord {
  id                 String              @id @default(cuid())
  clientId           String
  serviceId          String
  employeeId         String?
  branchId           String              @map("businessId")
  boxNumber          String?
  paymentMode        PaymentMode         @default(CASH)
  amount             Float               @default(0)
  comment            String?
  status             ServiceRecordStatus @default(CREATED)
  completedAt        DateTime?
  overrideReason     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  damageFee          Float               @default(0)
  netAmount          Float               @default(0)
  platformFee        Float               @default(0)
  taxAmount          Float               @default(0)
  employeeCommission Float               @default(0)
  extraServices      Json?               @default("[]")
  commissionLog      CommissionLog?
  branch             Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  client             Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee           Employee?           @relation(fields: [employeeId], references: [id])
  service            Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  review             Review?

  // Indexes for the most common query patterns:
  // - listing/filtering by branch + status (operations page)
  // - revenue reports by branch + status + completedAt
  // - loyalty & groupBy queries by clientId + branchId
  // - employee commission queries by employeeId
  @@index([branchId, status])
  @@index([branchId, status, completedAt])
  @@index([clientId, branchId])
  @@index([employeeId])
  @@map("service_records")
}

model CommissionLog {
  id              String        @id @default(cuid())
  serviceRecordId String        @unique
  employeeId      String
  amount          Float
  status          String        @default("UNPAID")
  payoutId        String?
  createdAt       DateTime      @default(now())
  employee        Employee      @relation(fields: [employeeId], references: [id])
  serviceRecord   ServiceRecord @relation(fields: [serviceRecordId], references: [id])
  payout          EmployeePayout? @relation(fields: [payoutId], references: [id])

  // Settlement queries filter by employeeId + status
  @@index([employeeId, status])
  @@map("commission_logs")
}

model Supplier {
  id          String       @id @default(cuid())
  name        String
  email       String?
  phone       String?
  category    String?      // e.g., "Essential Oils", "Linens", "Wood & Charcoal"
  address     String?
  notes       String?
  status      EntityStatus @default(ACTIVE)
  branchId    String       @map("businessId")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  inventory   Inventory[]

  @@map("suppliers")
}

model Inventory {
  id           String         @id @default(cuid())
  productName  String
  stockCount   Int            @default(0)
  minThreshold Int            @default(5)
  unit         String         @default("pcs")
  supplierId   String?
  branchId     String         @map("businessId")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier     Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  logs         InventoryLog[]

  @@map("inventory")
}

model InventoryLog {
  id          String   @id @default(cuid())
  inventoryId String
  type        String   // "RESTOCK" or "USAGE"
  quantity    Int
  notes       String?
  performedBy String?  // userId who performed the action
  branchId    String   @map("businessId")
  createdAt   DateTime @default(now())
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("inventory_logs")
}

model LoyaltyProgram {
  id           String       @id @default(cuid())
  branchId     String       @unique @map("businessId")
  pointsPerRwf Float        @default(0.01)
  buyCount     Int?
  getCount     Int?
  status       EntityStatus @default(ACTIVE)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("loyalty_programs")
}

model LoyaltyPoint {
  id        String      @id @default(cuid())
  clientId  String
  points    Int         @default(0)
  tier      LoyaltyTier @default(BRONZE)
  branchId  String      @map("businessId")
  updatedAt DateTime    @updatedAt
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("loyalty_points")
}

model Compliance {
  id        String   @id @default(cuid())
  region    String   @unique
  taxRate   Float    @default(18.0)
  gdprFlag  Boolean  @default(false)
  currency  String   @default("RWF")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("compliance_settings")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  details   String?
  reason    String?
  branchId  String?  @map("businessId")
  createdAt DateTime @default(now())
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([branchId, createdAt])
  @@map("audit_logs")
}

model SafetyAlert {
  id        String      @id @default(cuid())
  type      AlertType   @default(SILENT)
  location  String?
  message   String?
  status    AlertStatus @default(PENDING)
  branchId  String      @map("businessId")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  branch    Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("safety_alerts")
}

model Broadcast {
  id        String   @id @default(cuid())
  subject   String
  content   String
  level     String
  target    String
  branchId  String?  @map("businessId")
  isDraft   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("broadcasts")
}

model Settlement {
  id              String           @id @default(cuid())
  businessId      String
  branchId        String
  periodStart     DateTime
  periodEnd       DateTime
  totalGross      Float            @default(0)
  totalCommission Float            @default(0)
  totalNet        Float            @default(0)
  status          SettlementStatus @default(PENDING)
  payoutRef       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("settlements")
}

model Review {
  id              String        @id @default(cuid())
  rating          Int
  comment         String?
  serviceRecordId String        @unique
  clientId        String
  employeeId      String
  branchId        String        @map("businessId")
  createdAt       DateTime      @default(now())
  
  serviceRecord   ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Shift {
  id          String      @id @default(cuid())
  employeeId  String
  branchId    String      @map("businessId")
  date        DateTime
  startTime   String
  endTime     String
  status      ShiftStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("shifts")
}

model EmployeePayout {
  id          String           @id @default(cuid())
  employeeId  String
  branchId    String           @map("businessId")
  amount      Float
  status      PayoutStatus     @default(PENDING)
  paidAt      DateTime?
  reference   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch        Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  commissionLogs CommissionLog[]

  @@map("employee_payouts")
}

enum UserRole {
  ADMIN
  OWNER
  MANAGER
  EMPLOYEE
  RECEPTIONIST
}

enum ClientType {
  MEMBER
  WALK_IN
}

enum MembershipType {
  SUBSCRIPTION
  LIST_PASS
  FREE_PASS
}

enum PaymentMode {
  CASH
  MOMO
  POS
  MEMBERSHIP
}

enum ServiceRecordStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  CANCELLED

}

enum EntityStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum AlertType {
  SILENT
  CRITICAL
}

enum AlertStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
}

enum SettlementStatus {
  PENDING
  PAID
  FAILED
}

enum ShiftStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PAID
  CANCELLED
}
